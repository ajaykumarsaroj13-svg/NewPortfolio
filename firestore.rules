rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Hardened Reusable Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Bootstrapped Admin Verification:
      // Includes the primary user email from runtime metadata (ajaykumarsaroj13@gmail.com)
      // as well as standard admin credentials or Firestore record roles.
      return isSignedIn() && (
        request.auth.token.email == 'ajaykumarsaroj13@gmail.com' ||
        request.auth.token.email == 'admin@quantrex.edu' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Schema Validators
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'name', 'role']) &&
             data.keys().size() <= 8 &&
             data.id is string && data.id.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.role in ['student', 'admin', 'guest'];
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'fee', 'tag']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 150 &&
             data.fee is number && data.fee >= 0;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['id', 'title', 'chapter', 'category', 'fileUrl', 'contentPreview']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.chapter is string && data.chapter.size() <= 100 &&
             data.fileUrl is string && data.fileUrl.size() <= 5000000; // Allow large base64 strings
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['id', 'title', 'chapter', 'category', 'videoUrl']) &&
             data.id is string && data.id.size() <= 128 &&
             data.videoUrl is string && data.videoUrl.size() <= 5000000; // Allow object blob URLs or long links
    }

    function isValidPYQ(data) {
      return data.keys().hasAll(['id', 'year', 'exam', 'chapter', 'title', 'questionText', 'solutionText']) &&
             data.id is string && data.id.size() <= 128;
    }

    // Firestore matches
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && (
        // Block self privilege escalation: cannot set role to admin unless already admin
        (incoming().role == existing().role || isAdmin()) &&
        // Block email updates
        incoming().email == existing().email
      );
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notes/{noteId} {
      allow read: if true;
      allow write: if isAdmin() && isValidNote(incoming());
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin() && isValidVideo(incoming());
    }

    match /pyqs/{pyqId} {
      allow read: if true;
      allow write: if isAdmin() && isValidPYQ(incoming());
    }
  }
}
