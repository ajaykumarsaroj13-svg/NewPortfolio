{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing roles, study progress, test history, and purchase records",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "student",
            "admin"
          ]
        },
        "purchasedCourses": {
          "type": "array"
        },
        "testHistory": {
          "type": "array"
        },
        "avatarUrl": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "email",
        "name",
        "role"
      ]
    },
    "Course": {
      "title": "Course",
      "description": "Academic course core module offered by Quantrex HOD Desk",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "fee": {
          "type": "number"
        },
        "rating": {
          "type": "number"
        },
        "durationMonths": {
          "type": "number"
        },
        "lecturesCount": {
          "type": "number"
        },
        "syllabus": {
          "type": "array"
        },
        "bannerUrl": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "description",
        "fee",
        "tag"
      ]
    },
    "LectureNote": {
      "title": "LectureNote",
      "description": "Proprietary high-protection solved mathematics PDF or document lecture sheets",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "chapter": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "fileUrl": {
          "type": "string"
        },
        "contentPreview": {
          "type": "string"
        },
        "isPremium": {
          "type": "boolean"
        },
        "pageCount": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "title",
        "chapter",
        "category",
        "fileUrl",
        "contentPreview"
      ]
    },
    "VideoLecture": {
      "title": "VideoLecture",
      "description": "Secure streaming lecture video files published into the video vault",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "chapter": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "videoUrl": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "isPremium": {
          "type": "boolean"
        },
        "faculty": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "chapter",
        "category",
        "videoUrl"
      ]
    },
    "PYQ": {
      "title": "PYQ",
      "description": "Previous Year Questions with official solutions and step-by-step math explanations",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "year": {
          "type": "number"
        },
        "exam": {
          "type": "string"
        },
        "chapter": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "questionImageUrl": {
          "type": "string"
        },
        "questionText": {
          "type": "string"
        },
        "options": {
          "type": "array"
        },
        "correctAnswer": {
          "type": "string"
        },
        "solutionText": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "year",
        "exam",
        "chapter",
        "title",
        "questionText",
        "solutionText"
      ]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles, roles, and course purchases"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Course packages published on core database"
    },
    "/notes/{noteId}": {
      "schema": "LectureNote",
      "description": "Lecture sheets published by HOD admin desk"
    },
    "/videos/{videoId}": {
      "schema": "VideoLecture",
      "description": "Video streams available to enrolled students"
    },
    "/pyqs/{pyqId}": {
      "schema": "PYQ",
      "description": "Solved historic previous year JEE question resources"
    }
  }
}
